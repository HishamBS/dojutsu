{
  "project_types": {
    "typescript": {
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "type_check": "npx tsc --noEmit",
      "lint": "npx eslint . --ext .ts,.tsx",
      "test": "npx jest --passWithNoTests"
    },
    "python": {
      "extensions": [".py"],
      "type_check": "python3 -m mypy .",
      "lint": "python3 -m ruff check .",
      "test": "python3 -m pytest -q"
    },
    "java": {
      "extensions": [".java", ".kt"],
      "type_check": "mvn compile -q",
      "lint": "mvn checkstyle:check -q",
      "test": "mvn test -q"
    },
    "go": {
      "extensions": [".go"],
      "type_check": "go build ./...",
      "lint": "golangci-lint run",
      "test": "go test ./..."
    },
    "rust": {
      "extensions": [".rs"],
      "type_check": "cargo check",
      "lint": "cargo clippy",
      "test": "cargo test"
    }
  }
}
